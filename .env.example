# Copy to .env and adjust. NEVER commit .env (it is gitignored).
# docker-compose, the MCP server, the hooks, and the scripts all read these.

# ── SurrealDB credentials ────────────────────────────────────────────────
# CHANGE THESE before exposing the DB beyond localhost. root/root is a
# convenience default for a local-only dev setup.
SURREALDB_USER=root
SURREALDB_PASS=root

# ── Connection target ────────────────────────────────────────────────────
# These override the values in projects.json when set.
SURREALDB_URL=http://localhost:8200
SURREALDB_NS=ai
SURREALDB_DB=memory

# ── docker-compose host ports (optional) ─────────────────────────────────
SURREAL_PORT=8200
SURREALIST_PORT=8201

# ── Config discovery (optional) ──────────────────────────────────────────
# Explicit path to your projects.json. If unset, discovery order is:
#   $BRETHOF_MIND_CONFIG  →  ~/.config/brethof-mind/projects.json  →  ./projects.json
# BRETHOF_MIND_CONFIG=/home/you/.config/brethof-mind/projects.json
